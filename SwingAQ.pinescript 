//@version=6
indicator(title="SwingByAQib", shorttitle="SwingAQ", overlay=true)

// =====================
// === SwingByAQib ===
// =====================
magicCon = input.int(9, minval=1, title="Magic Line")
donchian(len) => math.avg(ta.lowest(len), ta.highest(len))
magicLine = donchian(magicCon)
plot(magicLine, color=#2962FF, title="Magic Line", linewidth=2)

// =====================
// === CCI ===
// =====================
cciLength  = input.int(33, minval=1, title="CCI Length")
src        = input(hlc3, title="CCI Source")
windowBars = input.int(3, minval=1, maxval=10, title="Window Bar harga (±cross)")

cciMA = ta.sma(src, cciLength)
cci   = (src - cciMA) / (0.015 * ta.dev(src, cciLength))

// =====================
// === SL Settings ===
// =====================
slLookback = input.int(20, minval=5, maxval=100, title="SL Lookback (bar terakhir)")
slLineLen  = input.int(6, minval=1, maxval=30,   title="Panjang Garis SL (bar)")

// Swing low = lowest low dalam N bar terakhir (real-time, tanpa delay)
recentSwingLow = ta.lowest(low, slLookback)

// =====================
// === Tracking ===
// =====================
var bool everBelow100 = false
var bool pendingBuy   = false
var int  pendingBar   = 0

if cci < -100
    everBelow100 := true

// =====================
// === Events ===
// =====================
crossUpMinus100 = ta.crossover(cci, -100)
crossDown100    = ta.crossunder(cci, 100)

priceAboveWindow = false
for i = 0 to windowBars - 1
    if close[i] > magicLine[i]
        priceAboveWindow := true

// =====================
// === BUY Logic ===
// =====================
if crossUpMinus100 and everBelow100[1]
    pendingBuy   := true
    pendingBar   := 0
    everBelow100 := false

if pendingBuy
    pendingBar += 1

cciBullish = false
if pendingBuy and priceAboveWindow
    cciBullish := true
    pendingBuy := false
    pendingBar := 0

if pendingBuy and pendingBar > windowBars
    pendingBuy := false
    pendingBar := 0

// =====================
// === SELL Logic ===
// =====================
cciBearish = crossDown100

// =====================
// === Plots ===
// =====================
plotshape(cciBullish,
     title="BUY", location=location.belowbar,
     color=color.new(color.green, 0), style=shape.arrowup,
     size=size.normal, text="BUY")

plotshape(cciBearish,
     title="SELL", location=location.abovebar,
     color=color.new(color.red, 0), style=shape.arrowdown,
     size=size.normal, text="SELL")

// =====================
// === SL: garis pendek + label setiap BUY ===
// =====================
if cciBullish
    slVal = recentSwingLow
    line.new(
         x1    = bar_index - slLineLen,
         y1    = slVal,
         x2    = bar_index + slLineLen,
         y2    = slVal,
         color = color.new(color.red, 0),
         width = 1,
         style = line.style_dashed
         )
    label.new(
         x         = bar_index + slLineLen,
         y         = slVal,
         text      = "SL: " + str.tostring(slVal, "#.##"),
         color     = color.new(color.red, 20),
         textcolor = color.white,
         style     = label.style_label_left,
         size      = size.small
         )

// =====================
// === Alert ===
// =====================
alertcondition(cciBullish, title="BUY",  message="CCI cross -100 dari bawah + harga > Magic Line")
alertcondition(cciBearish, title="SELL", message="CCI cross turun dari 100")